# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=  # comma-separated Telegram user IDs for DM whitelist
TELEGRAM_ALLOWED_GROUP_IDS= # comma-separated Telegram group chat IDs

# Claude Code
CLAUDE_CONFIG_DIR=/data/.claude  # persistent volume path for auth tokens + sessions

# Data
DATA_DIR=/data  # Railway persistent volume mount point

# Timezone
TIMEZONE=America/New_York

# OpenAI (for Whisper voice transcription)
OPENAI_API_KEY=

# Resy
RESY_API_KEY=           # API key from browser network traffic (or use shared key)
RESY_EMAIL=             # Resy account email
RESY_PASSWORD=          # Resy account password

# OpenTable (extract from browser dev tools — see scripts/setup-opentable.sh)
OPENTABLE_CSRF_TOKEN=   # X-Csrf-Token header from browser network traffic
OPENTABLE_COOKIES=      # Cookie header from authenticated OpenTable session
OPENTABLE_GPID=         # Diner profile ID (from request payloads)
OPENTABLE_FIRST_NAME=   # For booking payload
OPENTABLE_LAST_NAME=    # For booking payload
OPENTABLE_EMAIL=        # For booking payload
OPENTABLE_PHONE=        # For booking payload (e.g. +12125551234)
